{
  "name": "generateporn-media-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:wifi": "vite --host 0.0.0.0",
    "start:api": "REDIRECT_STATIC_TO_VITE=false node src/server.ts",
    "typecheck": "tsc -b",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "build": "pnpm typecheck && vite build",
    "start": "node scripts/start-local.mjs",
    "start:wifi": "HOST=0.0.0.0 node scripts/start-local.mjs",
    "tailscale:funnel": "tailscale --socket=/opt/homebrew/var/run/tailscale/tailscaled.sock funnel --bg --https=443 localhost:${PORT:-6177}",
    "tailscale:funnel:off": "tailscale --socket=/opt/homebrew/var/run/tailscale/tailscaled.sock funnel --https=443 off",
    "tailscale:funnel:status": "tailscale --socket=/opt/homebrew/var/run/tailscale/tailscaled.sock funnel status",
    "test": "pnpm build && pnpm test:unit && node --test --test-concurrency=1 \"test/*.test.js\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "1.0.0-rc.3",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "8.0.0-rc.4",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": "26.2.0",
    "pnpm": "11.3.0"
  },
  "packageManager": "pnpm@11.3.0"
}
