{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc", "unicorn", "import", "promise", "node", "react", "react-perf", "jsx-a11y", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2026": true
  },
  "ignorePatterns": ["node_modules/**", "public/**", "media/**", "output/**", "research/**", "extension/**", "*.har"],
  "settings": {
    "react": {
      "version": "19.2.6"
    }
  },
  "rules": {
    "no-console": "off",
    "no-await-in-loop": "off",
    "no-underscore-dangle": "off",
    "import/no-unassigned-import": "off",
    "react/react-in-jsx-scope": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off"
  },
  "overrides": [
    {
      "files": ["client/src/**/*.test.{ts,tsx}", "test/**/*.test.js"],
      "env": {
        "vitest": true,
        "node": true,
        "browser": true
      },
      "rules": {
        "no-empty-function": "off",
        "promise/no-multiple-resolved": "off"
      }
    },
    {
      "files": ["src/**/*.js", "test/**/*.js", "*.config.ts"],
      "env": {
        "node": true,
        "browser": false
      }
    },
    {
      "files": ["client/src/**/*.{ts,tsx}"],
      "env": {
        "browser": true,
        "node": false
      }
    }
  ]
}
