PORT=5177

# Files and catalog.json are stored here by default. Relative paths are resolved
# from this repo. Absolute paths are useful for mounted remote drives, e.g.
# MEDIA_DIR=/Volumes/RemoteDrive/gp-media-library
# MEDIA_DIR=~/Library/CloudStorage/Dropbox/gp-media-library
MEDIA_DIR=media

# Optional fallback. The API uses a short-lived Clerk bearer token from:
# await window.Clerk?.session?.getToken()
#
# Prefer the Chrome extension's "Send auth to local app" button. It sends a
# fresh token to the local server in memory. Static tokens in .env expire fast.
GENERATEPORN_AUTHORIZATION=
GENERATEPORN_COOKIE=

# Optional JSON object for extra API headers, for example:
# GENERATEPORN_EXTRA_HEADERS_JSON={"x-example":"value"}
GENERATEPORN_EXTRA_HEADERS_JSON=

GENERATEPORN_PAGE_LIMIT=1000

# Optional. Used for video poster thumbnail generation. Defaults to `ffmpeg`
# from PATH.
FFMPEG_PATH=ffmpeg
