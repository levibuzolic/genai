PORT=5177

# Files and catalog.sqlite are stored here by default. Relative paths are resolved
# from this repo. Absolute paths are useful for mounted remote drives, e.g.
# MEDIA_DIR=/Volumes/RemoteDrive/gp-media-library
# MEDIA_DIR=~/Library/CloudStorage/Dropbox/gp-media-library
MEDIA_DIR=media

# Auth browser defaults. The app can open a visible browser for initial
# email/password/OTP login, then reuse the same profile headlessly for refresh.
GENERATEPORN_APP_URL=https://app.generateporn.ai/
AUTH_BROWSER_PROFILE_DIR=
AUTH_BROWSER_REFRESH_MS=900000
AUTH_BROWSER_CHANNEL=chrome

# Optional fallback. The API uses a short-lived Clerk bearer token from:
# await window.Clerk?.session?.getToken()
#
# Prefer the in-app auth browser. The legacy Chrome extension can still send a
# fresh token to the local server in memory. Static tokens in .env expire fast.
GENERATEPORN_AUTHORIZATION=
GENERATEPORN_COOKIE=

# Optional JSON object for extra API headers, for example:
# GENERATEPORN_EXTRA_HEADERS_JSON={"x-example":"value"}
GENERATEPORN_EXTRA_HEADERS_JSON=

GENERATEPORN_PAGE_LIMIT=1000

# Automatic background sync. When enabled, the Node server runs an incremental
# sync shortly after boot and then repeats on the configured interval.
AUTO_SYNC_ENABLED=true
AUTO_SYNC_STARTUP_DELAY_MS=10000
AUTO_SYNC_INTERVAL_MS=3600000

# Optional. Used for video poster thumbnail generation. Defaults to `ffmpeg`
# from PATH.
FFMPEG_PATH=ffmpeg
